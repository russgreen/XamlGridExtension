<UserControl x:Class="XAMLGridEditor.ToolWindow.GridEditorToolWindowControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="300"
             Background="{DynamicResource VsBrush.Window}"
             Foreground="{DynamicResource VsBrush.WindowText}">

    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Grid dimensions summary -->
        <TextBlock Grid.Row="0"
                   Text="{Binding GridSummary}"
                   FontWeight="SemiBold"
                   Margin="0,0,0,8"/>

        <!-- Row section header -->
        <TextBlock Grid.Row="1" Text="Rows" FontWeight="Bold" Margin="0,0,0,4"/>

        <!-- Row list -->
        <Grid Grid.Row="2" Margin="0,0,0,8">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <ListView Grid.Row="0"
                      ItemsSource="{Binding Rows}"
                      SelectedItem="{Binding SelectedRow}"
                      MinHeight="60">
                <ListView.View>
                    <GridView>
                        <GridViewColumn Header="#" Width="30"
                                        DisplayMemberBinding="{Binding Index}"/>
                        <GridViewColumn Header="Height" Width="100">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBox Text="{Binding Size, UpdateSourceTrigger=LostFocus}"
                                             BorderThickness="0"
                                             Background="Transparent"
                                             Padding="2,0"
                                             LostFocus="SizeTextBox_LostFocus"
                                             KeyDown="SizeTextBox_KeyDown"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                    </GridView>
                </ListView.View>
            </ListView>

            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,4,0,0">
                <Button Content="Insert Before"
                        Command="{Binding InsertRowBeforeCommand}"
                        MinWidth="90" Margin="0,0,4,0"/>
                <Button Content="Insert After"
                        Command="{Binding InsertRowAfterCommand}"
                        MinWidth="90" Margin="0,0,4,0"/>
                <Button Content="Remove"
                        Command="{Binding RemoveRowCommand}"
                        MinWidth="70"/>
            </StackPanel>
        </Grid>

        <!-- Column section header -->
        <TextBlock Grid.Row="3" Text="Columns" FontWeight="Bold" Margin="0,0,0,4"
                   VerticalAlignment="Top"/>

        <!-- Column list (positioned inside row 3 after the header) -->
        <Grid Grid.Row="3" Margin="0,24,0,8">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <ListView Grid.Row="0"
                      ItemsSource="{Binding Columns}"
                      SelectedItem="{Binding SelectedColumn}"
                      MinHeight="60">
                <ListView.View>
                    <GridView>
                        <GridViewColumn Header="#" Width="30"
                                        DisplayMemberBinding="{Binding Index}"/>
                        <GridViewColumn Header="Width" Width="100">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBox Text="{Binding Size, UpdateSourceTrigger=LostFocus}"
                                             BorderThickness="0"
                                             Background="Transparent"
                                             Padding="2,0"
                                             LostFocus="SizeTextBox_LostFocus"
                                             KeyDown="SizeTextBox_KeyDown"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                    </GridView>
                </ListView.View>
            </ListView>

            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,4,0,0">
                <Button Content="Insert Before"
                        Command="{Binding InsertColumnBeforeCommand}"
                        MinWidth="90" Margin="0,0,4,0"/>
                <Button Content="Insert After"
                        Command="{Binding InsertColumnAfterCommand}"
                        MinWidth="90" Margin="0,0,4,0"/>
                <Button Content="Remove"
                        Command="{Binding RemoveColumnCommand}"
                        MinWidth="70"/>
            </StackPanel>
        </Grid>

        <!-- Status / warning area -->
        <TextBlock Grid.Row="4"
                   Text="{Binding StatusMessage}"
                   TextWrapping="Wrap"
                   Foreground="Orange"
                   Visibility="{Binding StatusVisibility}"
                   Margin="0,4,0,0"/>
    </Grid>
</UserControl>
